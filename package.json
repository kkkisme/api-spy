{
  "name": "api-spy",
  "version": "0.1.0",
  "description": "Frontend API monitoring SDK — intercepts XHR/fetch, captures page snapshot on error, reports non-blocking",
  "type": "module",
  "main": "./dist/api-spy.cjs",
  "module": "./dist/api-spy.js",
  "browser": "./dist/api-spy.iife.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/api-spy.js",
      "require": "./dist/api-spy.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && tsc --emitDeclarationOnly --declaration --outDir dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests --ext .ts",
    "serve": "node examples/server.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^1.5.0",
    "jsdom": "^24.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vite-plugin-dts": "^3.9.0",
    "vitest": "^1.5.0"
  },
  "peerDependencies": {
    "@zumer/snapdom": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "@zumer/snapdom": { "optional": true }
  },
  "dependencies": {
    "@zumer/snapdom": "^2.12.0"
  },
  "keywords": ["monitoring", "api", "xhr", "fetch", "screenshot", "error-reporting"],
  "license": "MIT"
}
